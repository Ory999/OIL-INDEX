# Secrets
.env
*.env

# Raw PDF and text files (large, regenerated by pipeline)
data/raw/opec_pdfs/
data/raw/eia_steo/
data/raw/aramco_texts/
data/raw/iea_texts/
data/raw/energy_sec/

# Raw data parquet files (large, regenerated daily)
# Exceptions: NLP corpus outputs must be committed for resume logic
data/raw/*.parquet
!data/raw/llm_scores.parquet
!data/raw/finbert_scores.parquet
!data/raw/combined_corpus.parquet
!data/raw/corpus_with_topics.parquet
!data/raw/opec_corpus.parquet
!data/raw/iea_corpus.parquet
!data/raw/aramco_corpus.parquet
!data/raw/eia_steo_corpus.parquet
!data/raw/energy_sec_corpus.parquet
!data/raw/sentiment_features.parquet

# Feature parquet files — ignore large intermediates but keep master datasets
data/features/*.parquet
!data/features/master_quant.parquet
!data/features/master_with_nlp.parquet

# Historic data directory — large binary files, not needed for public repo.
# Pipeline uses data/Historic/ locally only. Exclude to keep repo size small.
# The pipeline falls back gracefully when Historic/ is absent.
data/Historic/

# Local tooling config — LM Studio preset, not needed for running the pipeline
Semesterprojekt.preset.json

# Keep results CSVs, JSONs and PNGs (small, useful to track in git)
# data/results/ is NOT ignored — pipeline metadata and index output are committed

# Python cache
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# Jupyter
*.ipynb
